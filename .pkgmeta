# Build manifest for the BigWigs / CurseForge addon packager.
# https://github.com/BigWigsMods/packager
#
# This file controls how the packager builds the addon zip when a tag
# is pushed (via the GitHub Actions workflow under .github/workflows/).
# It guarantees that the resulting zip extracts to a folder named
# exactly "TTSGuildContributionManager", which is what WoW requires
# (the folder name MUST match the .toc file name without the extension).

package-as: TTSGuildContributionManager
curse-id: 1510516

# Files and directories that should NOT be included in the build zip.
# Anything build/dev-related stays out so the published addon is lean.
ignore:
  - .git
  - .github
  - .pkgmeta
  - .gitignore
  - README.md

# OPTIONAL: external libraries.
# Uncomment any block below to have the packager replace the in-repo
# copy of that library with a fresh checkout from upstream during the
# build. Useful if you want CurseForge releases to always ship the
# latest library version without manually updating the in-repo copy.
# Until uncommented, the in-repo copies under Libs/ are used as-is.
#
# externals:
#   Libs/LibStub: https://repos.wowace.com/wow/libstub/trunk
#   Libs/CallbackHandler-1.0: https://repos.wowace.com/wow/callbackhandler-1-0/trunk/CallbackHandler-1.0
#   Libs/AceAddon-3.0: https://repos.wowace.com/wow/ace3/trunk/AceAddon-3.0
#   Libs/AceConsole-3.0: https://repos.wowace.com/wow/ace3/trunk/AceConsole-3.0
#   Libs/AceDB-3.0: https://repos.wowace.com/wow/ace3/trunk/AceDB-3.0
#   Libs/AceEvent-3.0: https://repos.wowace.com/wow/ace3/trunk/AceEvent-3.0
#   Libs/AceGUI-3.0: https://repos.wowace.com/wow/ace3/trunk/AceGUI-3.0
#   Libs/AceConfig-3.0: https://repos.wowace.com/wow/ace3/trunk/AceConfig-3.0
#   Libs/AceDBOptions-3.0: https://repos.wowace.com/wow/ace3/trunk/AceDBOptions-3.0
#   Libs/LibDataBroker-1.1: https://repos.wowace.com/wow/libdatabroker-1-1/trunk
#   Libs/LibDBIcon-1.0: https://repos.wowace.com/wow/libdbicon-1-0/trunk/LibDBIcon-1.0
